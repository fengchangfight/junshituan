# ── LLM (DeepSeek) ────────────────────────────────────
OPENAI_API_KEY=sk-**
OPENAI_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-pro

# ── Embeddings (ZhipuAI embedding-2) ──────────────────
EMBEDDING_API_KEY=4**
# EMBEDDING_MODEL=embedding-2
# EMBEDDING_DIM=1024
# EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://junshituan:demopass@localhost:5432/junshituan
# POSTGRES_PASSWORD — docker-compose 用，需与 DATABASE_URL 中密码一致
POSTGRES_PASSWORD=demopass


# ── Budget ────────────────────────────────────────────
MAX_BUDGET_PER_SESSION_CNY=15.0
LLM_INPUT_PRICE_PER_M=2.0
LLM_OUTPUT_PRICE_PER_M=8.0

# ── SMS (Alibaba Cloud 号码认证) ─────────────────
ALIBABACLOUD_ACCESS_KEY_ID=your-aliyun-key-id
ALIBABACLOUD_ACCESS_KEY_SECRET=your-aliyun-key-secret
SMS_SIGN_NAME=军师团
SMS_TEMPLATE_CODE=SMS_100001

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=change-me-in-prod

# ── CORS ──────────────────────────────────────────────
CORS_ORIGINS=["https://www.junshituan.com"]

# ── pgAdmin ──────────────────────────────────────────
PGADMIN_EMAIL=admin@junshituan.com
PGADMIN_PASSWORD=your-pgadmin-password

# ── Frontend API ──────────────────────────────────────
NEXT_PUBLIC_API_URL=https://www.junshituan.com