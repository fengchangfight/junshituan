# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# Database (SQLite for dev, PostgreSQL for production)
# Dev: sqlite+aiosqlite:///./data/junshituan.db
# Prod: postgresql+asyncpg://user:pass@host/dbname
DATABASE_URL=sqlite+aiosqlite:///./data/junshituan.db

# Milvus (use Lite embedded for dev, set to false for standalone)
MILVUS_LITE=true
MILVUS_LITE_DB_PATH=./data/milvus_lite.db
# If using standalone Milvus:
# MILVUS_LITE=false
# MILVUS_HOST=localhost
# MILVUS_PORT=19530

# Personas & Uploads
PERSONAS_DIR=./data/personas
UPLOADS_DIR=./data/uploads

# Session
SESSION_TTL_HOURS=72
MAX_CONTEXT_TOKENS=8000

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=["http://localhost:3000"]
