# ── LLM (DeepSeek) ────────────────────────────────────
OPENAI_API_KEY=sk-your-deepseek-key
OPENAI_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-pro

# ── Embeddings ────────────────────────────────────────
# Dev (free): local BGE model via sentence-transformers
LOCAL_EMBEDDING=true
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# Prod (paid): switch to false, set OpenAI keys
# LOCAL_EMBEDDING=false
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-your-openai-key
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536

# ── Database ──────────────────────────────────────────
# Dev: SQLite (zero config)
# Prod: postgresql+asyncpg://user:pass@host/db
DATABASE_URL=sqlite+aiosqlite:///./data/junshituan.db

# ── Milvus ────────────────────────────────────────────
# Dev: embedded Lite (zero config)
# Prod: set LITE=false, point to Docker service
MILVUS_LITE=true
MILVUS_LITE_DB_PATH=./data/milvus_lite.db
# MILVUS_HOST=localhost
# MILVUS_PORT=19530

# ── Budget ────────────────────────────────────────────
MAX_BUDGET_PER_SESSION_CNY=15.0
LLM_INPUT_PRICE_PER_M=2.0
LLM_OUTPUT_PRICE_PER_M=8.0
# Only billed when LOCAL_EMBEDDING=false
EMBEDDING_PRICE_PER_M=0.5

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── CORS ──────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
